    },
    "components": {
        "schemas": {
            "RegisterResponse": {
                "properties": {
                    "token": {
                        "type": "string",
                        "example": "1|abc123..."
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "example": "john@test.com"
                    }
                },
                "type": "object"
            },
            "LoginResponse": {
                "properties": {
                    "token": {
                        "type": "string",
                        "example": "1|abc123..."
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "example": "john@test.com"
                    },
                    "role": {
                        "type": "string",
                        "example": "User"
                    }
                },
                "type": "object"
            },
            "Client": {
                "properties": {
                    "account_num": {
                        "type": "integer",
                        "example": 12345
                    },
                    "name": {
                        "type": "string",
                        "example": "Rakoto Andry"
                    },
                    "balance": {
                        "type": "number",
                        "format": "float",
                        "example": 1500
                    }
                },
                "type": "object"
            }
        },
        "responses": {
            "401": {
                "description": "Non authentifié"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "name": "bearerAuth",
                "in": "header",
                "bearerFormat": "Sanctum",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Clients",
            "description": "Clients"
        }
    ]
